-- ============================================================================
-- CREATE DESTINATION DATABASE AND SCHEMA
-- ============================================================================
-- Database: {{ dest_db }}
-- Schema:   {{ dest_schema }}
-- ============================================================================
-- REQUIRED ROLE: ACCOUNTADMIN (or SYSADMIN with CREATE DATABASE privilege)
-- ============================================================================

USE ROLE ACCOUNTADMIN;

-- ============================================================================
-- STEP 1: CREATE DESTINATION DATABASE
-- ============================================================================

CREATE DATABASE IF NOT EXISTS {{ dest_db | upper }}
  COMMENT = 'Destination database for Openflow Jira Cloud connector';

-- ============================================================================
-- STEP 2: CREATE DESTINATION SCHEMA
-- ============================================================================

CREATE SCHEMA IF NOT EXISTS {{ dest_db | upper }}.{{ dest_schema | upper }}
  COMMENT = 'Schema for Jira issues synced by Openflow connector';

-- ============================================================================
-- STEP 3: VERIFY
-- ============================================================================

SHOW DATABASES LIKE '{{ dest_db | upper }}';
SHOW SCHEMAS LIKE '{{ dest_schema | upper }}' IN DATABASE {{ dest_db | upper }};

-- NOTE: The destination table ({{ dest_table | upper }}) is created automatically
-- by the connector on its first run. No manual table creation is needed.
