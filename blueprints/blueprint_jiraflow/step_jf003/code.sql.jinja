-- ============================================================================
-- CREATE EXTERNAL ACCESS INTEGRATION FOR JIRA
-- ============================================================================
-- Network Rule: {{ rule_db }}.{{ rule_schema }}.JIRA_NETWORK_RULE
-- ============================================================================
-- REQUIRED ROLE: ACCOUNTADMIN
-- ============================================================================

USE ROLE ACCOUNTADMIN;

CREATE OR REPLACE EXTERNAL ACCESS INTEGRATION JIRA_EAI
  ALLOWED_NETWORK_RULES = ({{ rule_db | upper }}.{{ rule_schema | upper }}.JIRA_NETWORK_RULE)
  ENABLED = TRUE
  COMMENT = 'EAI for Openflow Jira Cloud connector';

-- Verify creation
SHOW EXTERNAL ACCESS INTEGRATIONS LIKE 'JIRA_EAI';
