-- ============================================================================
-- VALIDATE JIRA DATA IN SNOWFLAKE
-- ============================================================================
-- Destination: {{ dest_db }}.{{ dest_schema }}.{{ dest_table }}
-- ============================================================================
-- NOTE: Data appears within ~10 minutes of starting the flow.
--       One 5-min fetch cycle + one 5-min merge buffer flush.
-- ============================================================================

USE DATABASE {{ dest_db | upper }};
USE SCHEMA {{ dest_schema | upper }};

-- ============================================================================
-- STEP 1: CONFIRM TABLE WAS CREATED AND HAS ROWS
-- ============================================================================

SELECT COUNT(*) AS issue_count
FROM {{ dest_db | upper }}.{{ dest_schema | upper }}.{{ dest_table | upper }};

-- ============================================================================
-- STEP 2: SAMPLE ISSUE DATA
-- ============================================================================

SELECT
    ISSUE_KEY,
    PROJECT_KEY,
    ISSUE:fields:summary::STRING     AS summary,
    ISSUE:fields:status:name::STRING AS status,
    ISSUE:fields:issuetype:name::STRING AS issue_type,
    ISSUE:fields:assignee:displayName::STRING AS assignee,
    ISSUE:fields:created::TIMESTAMP_TZ AS created_at,
    ISSUE:fields:updated::TIMESTAMP_TZ AS updated_at
FROM {{ dest_db | upper }}.{{ dest_schema | upper }}.{{ dest_table | upper }}
ORDER BY updated_at DESC
LIMIT 10;

-- ============================================================================
-- STEP 3: PROJECT BREAKDOWN
-- ============================================================================

SELECT
    PROJECT_KEY,
    COUNT(*) AS issue_count,
    MAX(ISSUE:fields:updated::TIMESTAMP_TZ) AS last_updated
FROM {{ dest_db | upper }}.{{ dest_schema | upper }}.{{ dest_table | upper }}
GROUP BY PROJECT_KEY
ORDER BY issue_count DESC;
