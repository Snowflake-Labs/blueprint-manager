-- ============================================================================
-- CREATE DATA PRODUCT ROLES
-- ============================================================================
-- Data Product: {{ data_product_name }}
-- Domain: {{ data_product_domain }}
-- Environment: {{ data_product_environment }}
-- Role Structure: {{ role_structure }}
{%- if account_strategy != 'Single Account' %}
-- Target Account: {{ target_account_name | upper }}
{%- endif %}
-- ============================================================================
-- EXECUTE FROM: {% if account_strategy != 'Single Account' %}{{ target_account_name | upper }}{% else %}Primary Account{% endif %}
-- REQUIRED ROLE: USERADMIN
-- ============================================================================

USE ROLE USERADMIN;

-- ============================================================================
-- CREATE ROLE HIERARCHY
-- ============================================================================

-- Admin Role - Full administrative control
CREATE ROLE IF NOT EXISTS {{ data_product_name | upper }}_ADMIN
  COMMENT = 'Admin role for {{ data_product_name }} data product - {{ data_product_environment }} environment';

{%- if role_structure == 'Standard (Admin + Create + Read)' or role_structure == 'Full (Admin + Create + Write + Read)' %}

-- Create Role - Delegated object creation and grant management
CREATE ROLE IF NOT EXISTS {{ data_product_name | upper }}_CREATE
  COMMENT = 'Create role for {{ data_product_name }} data product - can create objects and manage grants';

{%- endif %}

{%- if role_structure == 'Full (Admin + Create + Write + Read)' %}

-- Write Role - Data modification privileges
CREATE ROLE IF NOT EXISTS {{ data_product_name | upper }}_WRITE
  COMMENT = 'Write role for {{ data_product_name }} data product - can modify data';

{%- endif %}

-- Read Role - Read-only access
CREATE ROLE IF NOT EXISTS {{ data_product_name | upper }}_READ
  COMMENT = 'Read role for {{ data_product_name }} data product - read-only access';

-- ============================================================================
-- ESTABLISH ROLE HIERARCHY
-- ============================================================================

-- Grant admin role to system role
GRANT ROLE {{ data_product_name | upper }}_ADMIN TO ROLE {{ admin_role_granted_to | upper }};

{%- if role_structure == 'Full (Admin + Create + Write + Read)' %}

-- Build hierarchy: Admin -> Create -> Write/Read
GRANT ROLE {{ data_product_name | upper }}_CREATE TO ROLE {{ data_product_name | upper }}_ADMIN;
GRANT ROLE {{ data_product_name | upper }}_WRITE TO ROLE {{ data_product_name | upper }}_CREATE;
GRANT ROLE {{ data_product_name | upper }}_READ TO ROLE {{ data_product_name | upper }}_CREATE;

{%- elif role_structure == 'Standard (Admin + Create + Read)' %}

-- Build hierarchy: Admin -> Create -> Read
GRANT ROLE {{ data_product_name | upper }}_CREATE TO ROLE {{ data_product_name | upper }}_ADMIN;
GRANT ROLE {{ data_product_name | upper }}_READ TO ROLE {{ data_product_name | upper }}_CREATE;

{%- else %}

-- Build hierarchy: Admin -> Read
GRANT ROLE {{ data_product_name | upper }}_READ TO ROLE {{ data_product_name | upper }}_ADMIN;

{%- endif %}

{%- if grant_account_access_roles == 'Yes - Grant account access roles (tasks, masking, tagging)' %}

-- ============================================================================
-- GRANT ACCOUNT ACCESS ROLES
-- ============================================================================
-- These roles provide account-level privileges for tasks, masking, tagging, etc.
-- Note: These roles must exist in the account (created in Account Creation workflow)

{%- if role_structure == 'Full (Admin + Create + Write + Read)' %}
{%- set target_role = data_product_name | upper ~ '_WRITE' %}
{%- else %}
{%- set target_role = data_product_name | upper ~ '_ADMIN' %}
{%- endif %}

-- Grant account access roles to {{ target_role }}
GRANT ROLE _AR_VIEW_AUSG TO ROLE {{ target_role }};
GRANT ROLE _AR_EXEC_TASK TO ROLE {{ target_role }};
GRANT ROLE _AR_APPLY_DDM TO ROLE {{ target_role }};
GRANT ROLE _AR_APPLY_RAP TO ROLE {{ target_role }};
GRANT ROLE _AR_APPLY_TAG TO ROLE {{ target_role }};

{%- endif %}

-- ============================================================================
-- VERIFICATION
-- ============================================================================

-- Show created roles
SHOW ROLES LIKE '%{{ data_product_name | upper }}%';

-- Verify role hierarchy
SELECT 
  grantee_name AS child_role,
  role AS parent_role
FROM SNOWFLAKE.ACCOUNT_USAGE.GRANTS_TO_ROLES
WHERE granted_on = 'ROLE'
  AND role LIKE '%{{ data_product_name | upper }}%'
ORDER BY role;

/*
ROLES CREATED
=============

Created role hierarchy for {{ data_product_name }} data product:
{%- if role_structure == 'Full (Admin + Create + Write + Read)' %}
- {{ data_product_name | upper }}_ADMIN (owns objects, grants to CREATE)
- {{ data_product_name | upper }}_CREATE (manages grants, creates objects)
- {{ data_product_name | upper }}_WRITE (modifies data{% if grant_account_access_roles == 'Yes - Grant account access roles (tasks, masking, tagging)' %}, has account access roles{% endif %})
- {{ data_product_name | upper }}_READ (reads data)
{%- elif role_structure == 'Standard (Admin + Create + Read)' %}
- {{ data_product_name | upper }}_ADMIN (owns objects, grants to CREATE{% if grant_account_access_roles == 'Yes - Grant account access roles (tasks, masking, tagging)' %}, has account access roles{% endif %})
- {{ data_product_name | upper }}_CREATE (manages grants, creates objects)
- {{ data_product_name | upper }}_READ (reads data)
{%- else %}
- {{ data_product_name | upper }}_ADMIN (owns objects{% if grant_account_access_roles == 'Yes - Grant account access roles (tasks, masking, tagging)' %}, has account access roles{% endif %})
- {{ data_product_name | upper }}_READ (reads data)
{%- endif %}

{%- if grant_account_access_roles == 'Yes - Grant account access roles (tasks, masking, tagging)' %}

Account access roles granted to {% if role_structure == 'Full (Admin + Create + Write + Read)' %}{{ data_product_name | upper }}_WRITE{% else %}{{ data_product_name | upper }}_ADMIN{% endif %}:
- _AR_VIEW_AUSG (View Account Usage)
- _AR_EXEC_TASK (Execute Tasks)
