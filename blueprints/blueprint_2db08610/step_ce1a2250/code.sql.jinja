-- ============================================================================
-- CONFIGURE ALERT NOTIFICATIONS
-- ============================================================================
-- Data Product: {{ data_product_name }}
{%- if account_strategy != 'Single Account' %}
-- Target Account: {{ target_account_name | upper }}
{%- endif %}
-- ============================================================================
-- EXECUTE FROM: {% if account_strategy != 'Single Account' %}{{ target_account_name | upper }}{% else %}Primary Account{% endif %}
-- REQUIRED ROLE: ACCOUNTADMIN
-- ============================================================================

USE ROLE ACCOUNTADMIN;

-- ============================================================================
-- DETERMINE MONITOR NAME BASED ON NAMING CONVENTION
-- ============================================================================

{%- if object_component_order == '<domain>_<env>_<dataproduct>' %}
{%- if account_strategy == 'Single Account' %}
{%- set monitor_name = data_product_domain | upper ~ '_' ~ data_product_environment | upper ~ '_' ~ data_product_name | upper ~ '_RESOURCE_MONITOR' %}
{%- elif account_strategy == 'Multi-Account (Environment-based)' %}
{%- set monitor_name = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_RESOURCE_MONITOR' %}
{%- elif account_strategy == 'Multi-Account (Domain-based)' %}
{%- set monitor_name = data_product_environment | upper ~ '_' ~ data_product_name | upper ~ '_RESOURCE_MONITOR' %}
{%- elif account_strategy == 'Multi-Account (Domain + Environment)' %}
{%- set monitor_name = data_product_name | upper ~ '_RESOURCE_MONITOR' %}
{%- endif %}
{%- elif object_component_order == '<domain>_<dataproduct>_<env>' %}
{%- if account_strategy == 'Single Account' %}
{%- set monitor_name = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ data_product_environment | upper ~ '_RESOURCE_MONITOR' %}
{%- elif account_strategy == 'Multi-Account (Environment-based)' %}
{%- set monitor_name = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_RESOURCE_MONITOR' %}
{%- elif account_strategy == 'Multi-Account (Domain-based)' %}
{%- set monitor_name = data_product_name | upper ~ '_' ~ data_product_environment | upper ~ '_RESOURCE_MONITOR' %}
{%- elif account_strategy == 'Multi-Account (Domain + Environment)' %}
{%- set monitor_name = data_product_name | upper ~ '_RESOURCE_MONITOR' %}
{%- endif %}
{%- elif object_component_order == '<env>_<domain>_<dataproduct>' %}
{%- if account_strategy == 'Single Account' %}
{%- set monitor_name = data_product_environment | upper ~ '_' ~ data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_RESOURCE_MONITOR' %}
{%- elif account_strategy == 'Multi-Account (Environment-based)' %}
{%- set monitor_name = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_RESOURCE_MONITOR' %}
{%- elif account_strategy == 'Multi-Account (Domain-based)' %}
{%- set monitor_name = data_product_environment | upper ~ '_' ~ data_product_name | upper ~ '_RESOURCE_MONITOR' %}
{%- elif account_strategy == 'Multi-Account (Domain + Environment)' %}
{%- set monitor_name = data_product_name | upper ~ '_RESOURCE_MONITOR' %}
{%- endif %}
{%- endif %}

-- ============================================================================
-- ADD NOTIFICATION RECIPIENTS
-- ============================================================================

-- Note: Resource monitor notifications go to account administrators by default.
-- Additional recipients can be added by granting MONITOR privilege on the account.
-- For email-based notifications to specific users, those users need notification access.

{%- if resource_monitor_emails and resource_monitor_emails | length > 0 %}
-- The following users should be configured to receive resource monitor alerts:
{%- for email in resource_monitor_emails %}
-- - {{ email }}
{%- endfor %}

-- To ensure these users receive notifications, they need to be account administrators
-- or have the ACCOUNTADMIN role to receive resource monitor alerts.

-- Alternative: Use account-level notification integration for custom routing
-- See: https://docs.snowflake.com/en/user-guide/notifications/notification-integrations

{%- else %}
-- Default notification: Account administrators will receive all alerts
{%- endif %}

-- ============================================================================
-- VERIFY NOTIFICATION SETTINGS
-- ============================================================================

-- Check resource monitor configuration
DESCRIBE RESOURCE MONITOR {{ monitor_name }};

-- List account administrators who will receive notifications
SHOW GRANTS TO ROLE ACCOUNTADMIN;

/*
NOTIFICATIONS CONFIGURED
========================

Resource monitor alerts will be sent when thresholds are crossed:
- 75%: Email notification
- 90%: Email notification
- 100%: Email notification + {{ resource_monitor_action }}

Recipients:
- All account administrators (default)
{%- if resource_monitor_emails and resource_monitor_emails | length > 0 %}
- Recommended additional recipients:
{%- for email in resource_monitor_emails %}
  - {{ email }}
{%- endfor %}
{%- endif %}
*/