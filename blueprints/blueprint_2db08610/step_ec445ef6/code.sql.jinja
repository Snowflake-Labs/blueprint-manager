{%- set db_name = data_product_environment | upper ~ '_' ~ data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Environment-based)' %}
{%- set db_name = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Domain-based)' %}
{%- set db_name = data_product_environment | upper ~ '_' ~ data_product_name | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Domain + Environment)' %}
{%- set db_name = data_product_name | upper ~ '_' ~ zone | upper %}
{%- endif %}
{%- endif %}

-- Admin gets DB_C from {{ zone | upper }} zone
GRANT DATABASE ROLE {{ db_name }}.DB_C TO ROLE {{ data_product_name | upper }}_ADMIN;

{%- endfor %}

{%- endif %}

-- ============================================================================
-- VERIFICATION
-- ============================================================================

-- Show grants to reader role
SHOW GRANTS TO ROLE {{ data_product_name | upper }}_READ;

{%- if role_structure == 'Full (Admin + Create + Write + Read)' %}
-- Show grants to writer role
SHOW GRANTS TO ROLE {{ data_product_name | upper }}_WRITE;
{%- endif %}

{%- if role_structure == 'Standard (Admin + Create + Read)' or role_structure == 'Full (Admin + Create + Write + Read)' %}
-- Show grants to admin role
SHOW GRANTS TO ROLE {{ data_product_name | upper }}_ADMIN;
{%- endif %}

/*
PRIVILEGES GRANTED (DATABASE ROLE PATTERN)
==========================================

{{ data_product_name | upper }}_READ:
- DB_R from {{ reader_db_name }}
- Access: All SC_R_* schema roles in {{ reader_zone_access }} zone
- Privileges: SELECT on tables, views, functions, etc.

{%- if role_structure == 'Full (Admin + Create + Write + Read)' %}

{{ data_product_name | upper }}_WRITE:
- DB_W from all zone databases
- Access: All SC_W_* schema roles in all zones
- Privileges: INSERT, UPDATE, DELETE, EXECUTE, OPERATE on tasks, etc.
{%- endif %}

{%- if role_structure == 'Standard (Admin + Create + Read)' or role_structure == 'Full (Admin + Create + Write + Read)' %}

{{ data_product_name | upper }}_ADMIN:
- DB_C from all zone databases
- Access: All SC_C_* schema roles in all zones
- Privileges: CREATE TABLE, CREATE VIEW, etc.
{%- endif %}

Role Hierarchy with Database Roles:
  Account Role    Database Role    Schema Roles
  ─────────────   ─────────────    ─────────────
  DP_READ     →      DB_R      ←  All SC_R_* roles
  DP_WRITE    →      DB_W      ←  All SC_W_* roles
  DP_ADMIN    →      DB_C      ←  All SC_C_* roles
*/