-- ============================================================================
-- GRANT ROLE PRIVILEGES (DATABASE ROLE PATTERN)
-- ============================================================================
-- Data Product: {{ data_product_name }}
-- Domain: {{ data_product_domain }}
-- Environment: {{ data_product_environment }}
-- Role Structure: {{ role_structure }}
-- Reader Zone: {{ reader_zone_access }}
{%- if account_strategy != 'Single Account' %}
-- Target Account: {{ target_account_name | upper }}
{%- endif %}
-- ============================================================================
-- EXECUTE FROM: {% if account_strategy != 'Single Account' %}{{ target_account_name | upper }}{% else %}Primary Account{% endif %}
-- REQUIRED ROLE: {{ data_product_name | upper }}_ADMIN
-- ============================================================================

USE ROLE {{ data_product_name | upper }}_ADMIN;

-- ============================================================================
-- READER ROLE: Grant DB_R from consumption zone
-- ============================================================================

{%- if object_component_order == '<domain>_<env>_<dataproduct>' %}
{%- if account_strategy == 'Single Account' %}
{%- set reader_db_name = data_product_domain | upper ~ '_' ~ data_product_environment | upper ~ '_' ~ data_product_name | upper ~ '_' ~ reader_zone_access | upper %}
{%- elif account_strategy == 'Multi-Account (Environment-based)' %}
{%- set reader_db_name = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ reader_zone_access | upper %}
{%- elif account_strategy == 'Multi-Account (Domain-based)' %}
{%- set reader_db_name = data_product_environment | upper ~ '_' ~ data_product_name | upper ~ '_' ~ reader_zone_access | upper %}
{%- elif account_strategy == 'Multi-Account (Domain + Environment)' %}
{%- set reader_db_name = data_product_name | upper ~ '_' ~ reader_zone_access | upper %}
{%- endif %}
{%- elif object_component_order == '<domain>_<dataproduct>_<env>' %}
{%- if account_strategy == 'Single Account' %}
{%- set reader_db_name = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ data_product_environment | upper ~ '_' ~ reader_zone_access | upper %}
{%- elif account_strategy == 'Multi-Account (Environment-based)' %}
{%- set reader_db_name = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ reader_zone_access | upper %}
{%- elif account_strategy == 'Multi-Account (Domain-based)' %}
{%- set reader_db_name = data_product_name | upper ~ '_' ~ data_product_environment | upper ~ '_' ~ reader_zone_access | upper %}
{%- elif account_strategy == 'Multi-Account (Domain + Environment)' %}
{%- set reader_db_name = data_product_name | upper ~ '_' ~ reader_zone_access | upper %}
{%- endif %}
{%- elif object_component_order == '<env>_<domain>_<dataproduct>' %}
{%- if account_strategy == 'Single Account' %}
{%- set reader_db_name = data_product_environment | upper ~ '_' ~ data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ reader_zone_access | upper %}
{%- elif account_strategy == 'Multi-Account (Environment-based)' %}
{%- set reader_db_name = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ reader_zone_access | upper %}
{%- elif account_strategy == 'Multi-Account (Domain-based)' %}
{%- set reader_db_name = data_product_environment | upper ~ '_' ~ data_product_name | upper ~ '_' ~ reader_zone_access | upper %}
{%- elif account_strategy == 'Multi-Account (Domain + Environment)' %}
{%- set reader_db_name = data_product_name | upper ~ '_' ~ reader_zone_access | upper %}
{%- endif %}
{%- endif %}

-- Reader gets DB_R from consumption zone ({{ reader_zone_access }})
-- This automatically includes all SC_R_* schema roles
GRANT DATABASE ROLE {{ reader_db_name }}.DB_R TO ROLE {{ data_product_name | upper }}_READ;

{%- if role_structure == 'Full (Admin + Create + Write + Read)' %}
-- ============================================================================
-- WRITER ROLE: Grant DB_W from all zones
-- ============================================================================

{%- for zone in zone_list %}

{%- if object_component_order == '<domain>_<env>_<dataproduct>' %}
{%- if account_strategy == 'Single Account' %}
{%- set db_name = data_product_domain | upper ~ '_' ~ data_product_environment | upper ~ '_' ~ data_product_name | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Environment-based)' %}
{%- set db_name = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Domain-based)' %}
{%- set db_name = data_product_environment | upper ~ '_' ~ data_product_name | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Domain + Environment)' %}
{%- set db_name = data_product_name | upper ~ '_' ~ zone | upper %}
{%- endif %}
{%- elif object_component_order == '<domain>_<dataproduct>_<env>' %}
{%- if account_strategy == 'Single Account' %}
{%- set db_name = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ data_product_environment | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Environment-based)' %}
{%- set db_name = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Domain-based)' %}
{%- set db_name = data_product_name | upper ~ '_' ~ data_product_environment | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Domain + Environment)' %}
{%- set db_name = data_product_name | upper ~ '_' ~ zone | upper %}
{%- endif %}
{%- elif object_component_order == '<env>_<domain>_<dataproduct>' %}
{%- if account_strategy == 'Single Account' %}
{%- set db_name = data_product_environment | upper ~ '_' ~ data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Environment-based)' %}
{%- set db_name = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Domain-based)' %}
{%- set db_name = data_product_environment | upper ~ '_' ~ data_product_name | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Domain + Environment)' %}
{%- set db_name = data_product_name | upper ~ '_' ~ zone | upper %}
{%- endif %}
{%- endif %}

-- Writer gets DB_W from {{ zone | upper }} zone
GRANT DATABASE ROLE {{ db_name }}.DB_W TO ROLE {{ data_product_name | upper }}_WRITE;

{%- endfor %}

{%- endif %}

-- ============================================================================
-- ADMIN ROLE: Grant DB_C from all zones (for delegated administration)
-- ============================================================================

{%- if role_structure == 'Standard (Admin + Create + Read)' or role_structure == 'Full (Admin + Create + Write + Read)' %}

{%- for zone in zone_list %}

{%- if object_component_order == '<domain>_<env>_<dataproduct>' %}
{%- if account_strategy == 'Single Account' %}
{%- set db_name = data_product_domain | upper ~ '_' ~ data_product_environment | upper ~ '_' ~ data_product_name | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Environment-based)' %}
{%- set db_name = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Domain-based)' %}
{%- set db_name = data_product_environment | upper ~ '_' ~ data_product_name | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Domain + Environment)' %}
{%- set db_name = data_product_name | upper ~ '_' ~ zone | upper %}
{%- endif %}
{%- elif object_component_order == '<domain>_<dataproduct>_<env>' %}
{%- if account_strategy == 'Single Account' %}
{%- set db_name = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ data_product_environment | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Environment-based)' %}
{%- set db_name = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Domain-based)' %}
{%- set db_name = data_product_name | upper ~ '_' ~ data_product_environment | upper ~ '_' ~ zone | upper %}
