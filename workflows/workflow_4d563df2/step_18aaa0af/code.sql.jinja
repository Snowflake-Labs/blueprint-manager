-- ============================================================================
-- ORGANIZATION ACCOUNT CONFIGURATION
-- ============================================================================
-- This script documents the Organization Account decision
-- Actual account creation is performed in Create Organization
-- Account (if applicable)
-- ============================================================================

{%- if org_account_name | upper != "NONE" %}
-- ============================================================================
-- VERIFY ORGADMIN PRIVILEGES
-- ============================================================================
-- Before creating an Organization Account, verify you have ORGADMIN privileges

USE ROLE ACCOUNTADMIN;

-- Check if ORGADMIN role exists and is granted
SHOW ROLES LIKE 'ORGADMIN';

-- List current roles to verify ORGADMIN access
SELECT CURRENT_ROLE();

-- Try to use ORGADMIN role (will fail if not granted)
-- USE ROLE ORGADMIN;

-- ============================================================================
-- VERIFY ORGANIZATION STATUS
-- ============================================================================

-- Check current organization
SELECT CURRENT_ORGANIZATION_NAME() AS organization_name;

-- List existing accounts in the organization (requires ORGADMIN)
-- SHOW ORGANIZATION ACCOUNTS;

-- ============================================================================
-- ORGANIZATION ACCOUNT PLANNING
-- ============================================================================

/*
Organization Account Configuration:
- Account Name: {{ org_account_name | upper }}
{%- if account_name_prefix | upper != "NONE" %}
- Full Account Name: {{ account_name_prefix }}_{{ org_account_name }}
- Account URL: https://{{ snowflake_org_name | lower }}-{{ account_name_prefix }}_{{ org_account_name }}.snowflakecomputing.com
{%- else %}
- Account URL: https://{{ snowflake_org_name | lower }}-{{ org_account_name }}.snowflakecomputing.com
{%- endif %}

Purpose:
- Centralized management of all Snowflake accounts
- Unified billing and cost management
- Organization-level policies and governance
- ORGADMIN privileges for account management

Note: The actual CREATE ACCOUNT command will be generated in the Create Organization Account step
*/

{%- else %}
-- ============================================================================
-- ORGANIZATION ACCOUNT NOT CONFIGURED
-- ============================================================================

/*
Decision: Organization Account will NOT be created at this time.

Implications:
- Single-account deployment without centralized management features
- Organization-level features are not available
- Can be enabled later if ORGADMIN role is available

Note: For multi-account strategies, an Organization Account is REQUIRED.
If you plan to expand to multiple accounts in the future, consider 
enabling the Organization Account for easier migration.
*/

-- Verify current account is properly configured for standalone operation
SELECT 
  CURRENT_ACCOUNT() AS current_account,
  CURRENT_ACCOUNT_NAME() AS account_name,
  CURRENT_ORGANIZATION_NAME() AS organization_name;

{%- endif %}