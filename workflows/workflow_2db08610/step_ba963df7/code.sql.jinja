{%- if account_strategy == 'Single Account' %}
{%- set wh_name = data_product_environment | upper ~ '_' ~ data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ wh.warehouse_name | upper ~ modifier_suffix %}
{%- elif account_strategy == 'Multi-Account (Environment-based)' %}
{%- set wh_name = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ wh.warehouse_name | upper ~ modifier_suffix %}
