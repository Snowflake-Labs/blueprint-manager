-- ============================================================================
-- ASSIGN ROLES TO USERS
-- ============================================================================
-- Data Product: {{ data_product_name }}
-- Domain: {{ data_product_domain }}
-- Environment: {{ data_product_environment }}
{%- if account_strategy != 'Single Account' %}
-- Target Account: {{ target_account_name | upper }}
{%- endif %}
-- ============================================================================
-- EXECUTE FROM: {% if account_strategy != 'Single Account' %}{{ target_account_name | upper }}{% else %}Primary Account{% endif %}
-- REQUIRED ROLE: SECURITYADMIN
-- ============================================================================

USE ROLE SECURITYADMIN;

-- ============================================================================
-- OWNER ROLE ASSIGNMENTS
-- ============================================================================

{%- for user in owner_users %}
GRANT ROLE {{ data_product_name | upper }}_ADMIN TO USER {{ user | upper }};
{%- endfor %}

-- ============================================================================
-- VERIFICATION
-- ============================================================================

-- Show owner role grants
SHOW GRANTS OF ROLE {{ data_product_name | upper }}_ADMIN;

/*
OWNER ROLE ASSIGNED
===================

{{ data_product_name | upper }}_ADMIN granted to:
{%- for user in owner_users %}
- {{ user | upper }}
{%- endfor %}

These users can now:
- USE ROLE {{ data_product_name | upper }}_ADMIN;
- Manage all data product resources
- Grant access to other users

NEXT STEPS: Managing Reader/Writer Access
==========================================

Reader and writer access should be managed through your organization's
access management process (SCIM, ServiceNow, access request workflows).

Example commands for future access grants:

-- Grant reader access
GRANT ROLE {{ data_product_name | upper }}_READ TO USER <username>;
GRANT ROLE {{ data_product_name | upper }}_READ TO ROLE <team_role>;

{%- if role_structure == 'Full (Admin + Create + Write + Read)' %}
-- Grant writer access (for ETL/data engineers)
GRANT ROLE {{ data_product_name | upper }}_WRITE TO USER <username>;
{%- endif %}

{%- if role_structure == 'Standard (Admin + Create + Read)' or role_structure == 'Full (Admin + Create + Write + Read)' %}
-- Grant admin access (for delegated management)
GRANT ROLE {{ data_product_name | upper }}_ADMIN TO USER <username>;
{%- endif %}

-- Revoke access
REVOKE ROLE {{ data_product_name | upper }}_READ FROM USER <username>;
*/