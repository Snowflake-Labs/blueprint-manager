-- ============================================================================
-- TRANSFER OWNERSHIP
-- ============================================================================
-- Data Product: {{ data_product_name }}
-- Domain: {{ data_product_domain }}
-- Environment: {{ data_product_environment }}
{%- if account_strategy != 'Single Account' %}
-- Target Account: {{ target_account_name | upper }}
{%- endif %}
-- ============================================================================
-- EXECUTE FROM: {% if account_strategy != 'Single Account' %}{{ target_account_name | upper }}{% else %}Primary Account{% endif %}
-- REQUIRED ROLE: ACCOUNTADMIN (for GRANT OWNERSHIP)
-- ============================================================================

USE ROLE ACCOUNTADMIN;

-- ============================================================================
-- TRANSFER DATABASE OWNERSHIP
-- ============================================================================

{%- for zone in zone_list %}

{#- Build database name based on component order and account strategy -#}
{%- if object_component_order == '<domain>_<env>_<dataproduct>' %}
{%- if account_strategy == 'Single Account' %}
{%- set db_name = data_product_domain | upper ~ '_' ~ data_product_environment | upper ~ '_' ~ data_product_name | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Environment-based)' %}
{%- set db_name = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Domain-based)' %}
{%- set db_name = data_product_environment | upper ~ '_' ~ data_product_name | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Domain + Environment)' %}
{%- set db_name = data_product_name | upper ~ '_' ~ zone | upper %}
{%- endif %}
{%- elif object_component_order == '<domain>_<dataproduct>_<env>' %}
{%- if account_strategy == 'Single Account' %}
{%- set db_name = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ data_product_environment | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Environment-based)' %}
{%- set db_name = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Domain-based)' %}
{%- set db_name = data_product_name | upper ~ '_' ~ data_product_environment | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Domain + Environment)' %}
{%- set db_name = data_product_name | upper ~ '_' ~ zone | upper %}
{%- endif %}
{%- elif object_component_order == '<env>_<domain>_<dataproduct>' %}
{%- if account_strategy == 'Single Account' %}
{%- set db_name = data_product_environment | upper ~ '_' ~ data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Environment-based)' %}
{%- set db_name = data_product_domain | upper ~ '_' ~ data_product_name | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Domain-based)' %}
{%- set db_name = data_product_environment | upper ~ '_' ~ data_product_name | upper ~ '_' ~ zone | upper %}
{%- elif account_strategy == 'Multi-Account (Domain + Environment)' %}
{%- set db_name = data_product_name | upper ~ '_' ~ zone | upper %}
{%- endif %}
{%- endif %}

-- ----------------------------------------------------------------------------
-- {{ zone | upper }} Zone Database
-- ----------------------------------------------------------------------------

-- Transfer database ownership
GRANT OWNERSHIP ON DATABASE {{ db_name }}
  TO ROLE {{ data_product_name | upper }}_ADMIN
  COPY CURRENT GRANTS;

-- Transfer schema ownership (all schemas in this database)
GRANT OWNERSHIP ON ALL SCHEMAS IN DATABASE {{ db_name }}
  TO ROLE {{ data_product_name | upper }}_ADMIN
  COPY CURRENT GRANTS;

{%- endfor %}

-- ============================================================================
