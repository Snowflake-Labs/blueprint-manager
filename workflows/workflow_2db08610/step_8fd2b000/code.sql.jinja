{%- endif %}
{%- endif %}

GRANT USAGE ON DATABASE {{ db_name }} TO ROLE SYSADMIN;
GRANT USAGE ON ALL SCHEMAS IN DATABASE {{ db_name }} TO ROLE SYSADMIN;

{%- endfor %}

